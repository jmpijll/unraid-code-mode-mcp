# =============================================================================
# Unraid Code-Mode MCP — Configuration
# =============================================================================
# Single-user mode: set the credentials below. The server reads these on startup
# and uses them for every request.
#
# Multi-user mode: leave the credentials below empty (or unset) and run with
# MCP_TRANSPORT=http. The MCP client must then send credentials in HTTP headers
# on each request:
#   X-Unraid-Base-Url, X-Unraid-Api-Key, X-Unraid-Insecure, X-Unraid-Ca-Cert
#
# Sandbox surface (in unraid.local.*):
#   - unraid.local.graphql({ query, variables, operationName })  raw GraphQL
#   - unraid.local.query.<fieldName>({ args, fields })           typed query
#   - unraid.local.mutation.<fieldName>({ args, fields })        typed mutation
#   - unraid.local.request({ method, path, body, headers })      raw HTTP escape hatch
#
# See docs/multi-tenant.md, docs/usage.md, and docs/security.md for details.
# =============================================================================

# ─── Transport ────────────────────────────────────────────────────────────
# stdio (default, single-user) | http (Streamable HTTP — required for multi-user)
MCP_TRANSPORT=stdio
MCP_HTTP_PORT=8000
# Comma-separated allowlist for HTTP transport (default: localhost only).
# Set to "*" to allow any origin (NOT recommended for production).
MCP_HTTP_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# ─── Unraid GraphQL API (per-server) ──────────────────────────────────────
# Base URL of your Unraid 7.2+ server, e.g. https://tower.local
# The server appends /graphql internally. Some Unraid installs only expose
# the GraphQL endpoint over HTTPS via the *.unraid.net LAN proxy; in that
# case use the unraid.net hostname (and provide the LAN CA / use insecure).
UNRAID_BASE_URL=
# API key minted with `unraid-api apikey --create --name "mcp" --roles ADMIN --json`
# or via the Unraid web UI: Settings → Management Access → API Keys.
UNRAID_API_KEY=
# Optional: path to a PEM file containing the CA bundle used to validate the
# server's TLS certificate (e.g. the Unraid root CA for *.unraid.net).
UNRAID_CA_CERT_PATH=
# Optional: skip TLS verification entirely. NOT recommended; use a CA cert.
# Accepted: true | false (default: false).
UNRAID_INSECURE=false

# ─── Sandbox Limits ───────────────────────────────────────────────────────
# Maximum API calls per execute() invocation.
UNRAID_MAX_CALLS_PER_EXECUTE=50

# ─── Spec Cache ───────────────────────────────────────────────────────────
# Where to cache fetched introspection results on disk.
# Defaults to ~/.cache/unraid-code-mode-mcp on supported platforms.
UNRAID_SPEC_CACHE_DIR=
